{
  "name": "@opsflow/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Lint not configured yet'",
    "db:generate": "node -r tsx/cjs node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node -r tsx/cjs node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node -r tsx/cjs node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node -r tsx/cjs node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "@opsflow/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.3.0",
    "jose": "^5.2.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.20",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
